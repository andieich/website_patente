---
import Base from '~/layouts/Base.astro';
import { type Lang, t, localePath } from '~/i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tt = t(lang);
const p = (path: string) => localePath(lang, path);
const alternates = { en: localePath('en', ''), fr: localePath('fr', '') };

const services = [
  { num: '01', href: p('services/fieldwork'),     label: tt('services.fw'),    sub: tt('services.fwSub') },
  { num: '02', href: p('services/statistics'),    label: tt('services.stats'), sub: tt('services.statsSub') },
  { num: '03', href: p('services/surveys'),       label: tt('services.surv'),  sub: tt('services.survSub') },
  { num: '04', href: p('services/documentation'), label: tt('services.doc'),   sub: tt('services.docSub') },
];

const aboutBlurb = lang === 'fr'
  ? "Biologiste marin avec plus d’une décennie d’expérience de terrain sur les récifs, sédiments côtiers et systèmes dulçaquicoles. Doctorant à l’EPHE et à l’Université Laval, je travaille sur l’adaptation des coraux aux changements environnementaux. Basé en Polynésie française, je propose des prestations de terrain, d’analyse et de documentation à travers ma patente."
  : "Marine biologist with over a decade of field experience across coral reefs, coastal sediments, and freshwater systems. PhD candidate at ÉPHE and Université Laval studying coral adaptation to environmental change. Based in French Polynesia, offering independent fieldwork, analytical, and documentation services through my patente.";

const servicesBlurb = lang === 'fr'
  ? "Quatre domaines de prestation pour la recherche marine et aquatique — de la conception de l’étude à la documentation finale. Disponible dans toute la Polynésie française."
  : "Four service areas for marine & aquatic research — from study design to final documentation. Available across French Polynesia.";
---
<Base lang={lang} title="Andreas Eich — Marine Biologist · French Polynesia" alternates={alternates} transparentNav>
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="eyebrow">{tt('footer.consulting')}</p>
      <h1>
        {tt('home.title1')}<br />
        <em>{tt('home.title2')}</em>
      </h1>
      <p class="lede">{tt('home.lede')}</p>
      <a href={p('contact')} class="btn-coral">{tt('home.cta')}</a>
    </div>
  </section>

  <section class="intro">
    <div class="container intro-grid">
      <div>
        <p class="eyebrow">{lang === 'fr' ? 'Qui suis-je' : 'Who I am'}</p>
        <h2 set:html={tt('home.whoTitle').replace('\n', '<br/>')}></h2>
        <p class="body">{aboutBlurb}</p>
        <a href={p('about')} class="link-underline">{tt('home.aboutLink')}</a>
      </div>
      <div>
        <p class="eyebrow">{lang === 'fr' ? 'Services' : 'Services'}</p>
        <h2 set:html={tt('home.servicesTitle').replace('\n', '<br/>')}></h2>
        <p class="body">{servicesBlurb}</p>
        <ul class="svc-list">
          {services.map(s => (
            <li>
              <a href={s.href}>
                <div>
                  <span class="lbl">{s.label}</span>
                  <span class="sub">{s.sub}</span>
                </div>
                <span class="arr">→</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    position: relative; height: 100vh; min-height: 580px;
    display: flex; align-items: center; overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background-image: url('/images/hero-fish-rays.jpg');
    background-size: cover; background-position: center 60%;
    background-color: var(--navy);
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to right, rgba(10,35,66,0.88) 0%, rgba(10,35,66,0.5) 55%, rgba(10,35,66,0.1) 100%);
  }
  .hero-content { position: relative; z-index: 2; max-width: 700px; padding: 0 4rem; }
  .hero-content .eyebrow { color: var(--coral); margin-bottom: 1rem; }
  .hero-content h1 {
    font-family: var(--serif); font-weight: 700;
    font-size: clamp(2.2rem, 4.5vw, 3.6rem); line-height: 1.15;
    color: var(--cream); margin: 0 0 1.25rem;
  }
  .hero-content h1 em { font-weight: 400; color: var(--cream-dk); font-style: italic; }
  .hero-content .lede {
    font-family: var(--sans); font-weight: 300; font-size: 1rem;
    color: rgba(232,220,200,0.85); line-height: 1.75;
    max-width: 480px; margin-bottom: 2.5rem;
  }

  .intro { padding: 7rem 0; }
  .intro-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
  .intro h2 { font-size: 2rem; margin: 0.5rem 0 1.5rem; line-height: 1.15; }
  .intro .body { font-size: 0.95rem; color: var(--text); line-height: 1.85; margin-bottom: 1.5rem; }

  .svc-list { list-style: none; margin-top: 2rem; }
  .svc-list li { border-bottom: 1px solid rgba(10,35,66,0.08); }
  .svc-list li:last-child { border-bottom: none; }
  .svc-list a {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.9rem 0; text-decoration: none; color: inherit;
    transition: opacity 0.15s;
  }
  .svc-list a:hover { opacity: 0.65; }
  .svc-list .lbl { font-family: var(--serif); font-weight: 600; font-size: 0.95rem; color: var(--navy); display: block; }
  .svc-list .sub { font-family: var(--sans); font-size: 0.8rem; color: var(--muted-2); margin-top: 2px; display: block; }
  .svc-list .arr { color: var(--coral); font-size: 1rem; }

  @media (max-width: 768px) {
    .hero-content { padding: 0 2rem; }
    .intro { padding: 4rem 0; }
    .intro-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>
