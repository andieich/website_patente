---
import { getCollection } from 'astro:content';
import Base from '~/layouts/Base.astro';
import PageHero from '~/components/PageHero.astro';
import { type Lang, t, localePath } from '~/i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tt = t(lang);
const p = (path: string) => localePath(lang, path);
const alternates = { en: localePath('en', 'news'), fr: localePath('fr', 'news') };

const allPosts = await getCollection('news', ({ data }) => !data.draft && data.lang === lang);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmtDate = (d: Date) => d.toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-GB', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---
<Base lang={lang} title={`${tt('nav.news')} — Andreas Eich`} alternates={alternates}>
  <PageHero
    lang={lang}
    title={tt('nav.news')}
    intro={tt('news.intro')}
    crumbs={[{ label: tt('breadcrumb.home'), href: p('') }, { label: tt('nav.news') }]}
  />

  <section class="content">
    <div class="container">
      <div class="grid">
        {posts.map(post => (
          <article class="card">
            <a href={p(`news/${post.data.translationKey}`)}>
              {post.data.image && (
                <div class="thumb">
                  <img src={typeof post.data.image === 'string' ? post.data.image : post.data.image.src} alt={post.data.imageAlt ?? ''} />
                </div>
              )}
              <div class="body">
                <p class="date">{fmtDate(post.data.date)}</p>
                <h2>{post.data.title}</h2>
                <p class="summary">{post.data.summary}</p>
                <span class="more">{tt('news.continueReading')}</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .content { padding: 4rem 0 6rem; background: var(--cream); }
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  @media (max-width: 900px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .grid { grid-template-columns: 1fr; } }

  .card {
    background: #fff; border: 1px solid rgba(10,35,66,0.07);
    border-radius: 6px; box-shadow: 0 2px 12px rgba(10,35,66,0.04);
    overflow: hidden; transition: transform 0.22s, box-shadow 0.22s;
  }
  .card:hover { transform: translateY(-4px); box-shadow: 0 10px 32px rgba(10,35,66,0.1); }
  .card a { text-decoration: none; color: inherit; display: block; }
  .thumb { aspect-ratio: 16 / 9; overflow: hidden; }
  .thumb img { width: 100%; height: 100%; object-fit: cover; }
  .body { padding: 1.5rem 1.25rem 1.5rem; }
  .date {
    font-family: var(--sans); font-size: 0.78rem; color: var(--muted-2);
    margin-bottom: 0.6rem;
  }
  h2 {
    font-family: var(--serif); font-weight: 600; font-size: 1.05rem;
    color: var(--navy); line-height: 1.4; margin: 0 0 0.6rem;
  }
  .summary {
    font-family: var(--sans); font-weight: 300; font-size: 0.875rem;
    color: var(--text); line-height: 1.65; margin: 0 0 1rem;
  }
  .more {
    font-family: var(--sans); font-size: 0.82rem; font-weight: 500;
    color: var(--coral);
  }
</style>
