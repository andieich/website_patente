---
import { type Lang, t, localePath } from '~/i18n/ui';
const { lang } = Astro.props as { lang: Lang };
const tt = t(lang);
const p = (path: string) => localePath(lang, path);
---
<footer>
  <div class="container">
    <div class="grid">
      <div>
        <div class="brand">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
            <path d="M4 20 Q8 12 16 16 Q24 20 28 12" stroke="var(--coral)" stroke-width="2.5" stroke-linecap="round" fill="none"/>
            <path d="M4 24 Q8 16 16 20 Q24 24 28 16" stroke="var(--muted)" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.6"/>
            <circle cx="16" cy="10" r="2.5" fill="var(--coral)" opacity="0.8"/>
          </svg>
          <span>Andreas Eich</span>
        </div>
        <p class="tagline">{tt('footer.tagline')}</p>
      </div>
      <div>
        <p class="label">{tt('footer.pages')}</p>
        <a href={p('about')}>{tt('nav.about')}</a>
        <a href={p('services')}>{tt('nav.services')}</a>
        <a href={p('news')}>{tt('nav.news')}</a>
        <a href={p('contact')}>{tt('nav.contact')}</a>
      </div>
      <div>
        <p class="label">{tt('footer.connect')}</p>
        <a href="https://orcid.org/0000-0002-9547-6487" target="_blank" rel="noopener">ORCID ↗</a>
        <a href="https://github.com/andieich" target="_blank" rel="noopener">GitHub ↗</a>
        <a href="mailto:eich.andreas@gmail.com" class="email">eich.andreas@gmail.com</a>
      </div>
    </div>
    <div class="legal">
      <p>{tt('footer.legal')}</p>
      <p>{tt('footer.consulting')}</p>
    </div>
  </div>
</footer>

<style>
  footer { background: var(--navy-deep); padding: 4rem 2.5rem 2rem; color: var(--cream); }
  .grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 4rem; margin-bottom: 3rem; }
  .brand { display: flex; align-items: center; gap: 10px; margin-bottom: 1rem; }
  .brand span { font-family: var(--serif); font-weight: 700; font-size: 1.1rem; }
  .tagline { font-size: 0.875rem; color: rgba(232,220,200,0.6); line-height: 1.7; max-width: 280px; }
  .label { font-family: var(--sans); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--coral); margin-bottom: 1rem; }
  footer a { display: block; padding: 3px 0; font-size: 0.85rem; color: rgba(232,220,200,0.6); text-decoration: none; }
  footer a:hover { color: var(--cream); }
  .email { color: var(--coral) !important; margin-top: 6px; }
  .legal { border-top: 1px solid rgba(255,255,255,0.07); padding-top: 1.5rem; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; }
  .legal p { font-size: 0.78rem; color: rgba(232,220,200,0.4); margin: 0; }
  .legal p:last-child { font-size: 0.72rem; color: rgba(232,220,200,0.3); }
  @media (max-width: 768px) { .grid { grid-template-columns: 1fr; gap: 2rem; } }
</style>
